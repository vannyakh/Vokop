{
  "name": "@vokop/ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./icons": "./src/icons/index.ts",
    "./shadcn": "./src/shadcn/index.ts",
    "./shadcn/*": "./src/shadcn/*",
    "./lib/utils": "./src/lib/utils.ts",
    "./lib/cn": "./src/lib/cn.ts",
    "./hooks/*": "./src/hooks/*",
    "./antd": "./src/antd/index.ts",
    "./styles.css": "./src/styles/base.css"
  },
  "scripts": {
    "lint": "tsc --noEmit",
    "clean": "echo 'nothing to clean'",
    "linecheck": "pnpm --filter @vokop/devtools exec tsx src/cli/linecheck-pkg.ts \"$PWD\"",
    "linecheck:fix": "pnpm --filter @vokop/devtools exec tsx src/cli/linecheck-pkg.ts --fix \"$PWD\"",
    "format": "pnpm --filter @vokop/devtools exec tsx src/cli/format-pkg.ts --write \"$PWD\"",
    "format:check": "pnpm --filter @vokop/devtools exec tsx src/cli/format-pkg.ts --check \"$PWD\""
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@shadcn/react": "^0.2.0",
    "antd": "^6.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.546.0",
    "next-themes": "^0.4.6",
    "react-day-picker": "^10.0.1",
    "react-resizable-panels": "^4.12.1",
    "recharts": "3.8.0",
    "shadcn": "^4.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@vokop/tsconfig": "workspace:*",
    "typescript": "~5.8.2"
  }
}
