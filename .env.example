# Database (Docker Compose)
MONGODB_URI=mongodb://vokop:vokop@localhost:27017/vokop?authSource=admin
REDIS_URL=redis://localhost:6379
CACHE_TTL_SEC=3600

# Stock media (server-only — proxied via /api/v1/media)
PIXABAY_API_KEY=
GIPHY_API_KEY=
MEDIA_CACHE_TTL_SEC=300

# AI (used by web app in dev; move to a backend service in production)
GEMINI_API_KEY=

# API Gateway
GATEWAY_PORT=4000
VIDEO_TOOLS_URL=http://localhost:4001
AUTH_SERVICE_URL=http://localhost:4002
WEB_ORIGIN=http://localhost:3000

# Auth service
AUTH_PORT=4002
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=604800
ADMIN_SEED_EMAIL=admin@vokop.app
ADMIN_SEED_PASSWORD=admin123456
ADMIN_SEED_NAME=Platform Admin

# Video tools service
VIDEO_TOOLS_PORT=4001
MAX_UPLOAD_MB=512
SESSION_TTL_SEC=86400
MAX_FFMPEG_JOBS=2
JOB_TTL_SEC=3600

# Optional: set when not using Vite dev proxy
# VITE_API_URL=http://localhost:4000
