# Database (Docker Compose)
MONGODB_URI=mongodb://vokop:vokop@localhost:27017/vokop?authSource=admin
REDIS_URL=redis://localhost:6379
# Dedicated Redis URL for BullMQ queues (falls back to REDIS_URL if not set)
BULL_REDIS_URL=
CACHE_TTL_SEC=3600

# Stock media (server-only — proxied via /api/v1/media or /api/v1/stock)
PIXABAY_API_KEY=
GIPHY_API_KEY=
MEDIA_CACHE_TTL_SEC=300

# AI content service (agent + multi-provider LLM registry)
# Default provider when request omits provider/model: gemini | openai | claude | 302ai
LLM_PROVIDER=gemini

# 302.AI unified gateway (recommended one-key access to many models)
# Docs: https://302.ai/  ·  https://302ai-en.apifox.cn/
AI_302_API_KEY=
AI_302_BASE_URL=https://api.302.ai
AI_302_MODEL=gpt-4o-mini
# AI_302_MODELS=gpt-4o-mini,gpt-4o,claude-sonnet-4-5,gemini-2.0-flash,deepseek-chat,qwen-plus

# Google Gemini (direct)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# GEMINI_MODELS=gemini-2.0-flash,gemini-2.5-flash,gemini-2.5-pro

# OpenAI (direct; optional OPENAI_BASE_URL for compatible proxies)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=
# OPENAI_MODELS=gpt-4o-mini,gpt-4o,o4-mini

# Anthropic Claude (direct)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5
# CLAUDE_MODELS=claude-sonnet-4-5,claude-haiku-4-5,claude-opus-4-5

AI_JOB_TTL_SEC=3600
AI_MAX_CONCURRENT_JOBS=2

# ── Cloudflare R2 Storage ────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public CDN base URL for R2 objects (e.g. https://pub-xxx.r2.dev)
# If omitted, the server generates presigned GET URLs for downloads
R2_PUBLIC_URL=

# ── Dev ports (one unique port per app/service) ─────────────────────────────
# Apps
WEB_PORT=3000
WEB_ORIGIN=http://localhost:3000
VITE_WEB_APP_URL=http://localhost:3000

ADMIN_PORT=3001
ADMIN_ORIGIN=http://localhost:3001
VITE_ADMIN_APP_URL=http://localhost:3001

# API gateway + backend services
GATEWAY_PORT=4000
VIDEO_TOOLS_PORT=4001
AUTH_PORT=4002
STUDIO_PORT=4003
ADMIN_SERVICE_PORT=4004
AI_CONTENT_PORT=4005
VIDEO_TOOLS_URL=http://localhost:4001
AUTH_SERVICE_URL=http://localhost:4002
STUDIO_SERVICE_URL=http://localhost:4003
ADMIN_SERVICE_URL=http://localhost:4004
AI_CONTENT_URL=http://localhost:4005

# Auth service
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=604800
ADMIN_SEED_EMAIL=admin@vokop.app
ADMIN_SEED_PASSWORD=admin123456
ADMIN_SEED_NAME=Platform Admin

# Video tools service
MAX_UPLOAD_MB=512
SESSION_TTL_SEC=86400
MAX_FFMPEG_JOBS=2
JOB_TTL_SEC=3600

# Optional: set when not using Vite dev proxy
# VITE_API_URL=http://localhost:4000
