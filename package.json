{
  "name": "vokop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "turbo run dev --parallel --filter=@vokop/web --filter=@vokop/admin --filter=@vokop/gateway --filter=@vokop/auth --filter=@vokop/studio --filter=@vokop/admin-service --filter=@vokop/video-tools --filter=@vokop/ai-content",
    "dev:web": "turbo run dev --parallel --filter=@vokop/web --filter=@vokop/gateway --filter=@vokop/auth --filter=@vokop/studio --filter=@vokop/video-tools --filter=@vokop/ai-content",
    "dev:admin": "turbo run dev --parallel --filter=@vokop/admin --filter=@vokop/gateway --filter=@vokop/auth --filter=@vokop/admin-service",
    "dev:services": "turbo run dev --parallel --filter=@vokop/gateway --filter=@vokop/auth --filter=@vokop/studio --filter=@vokop/admin-service --filter=@vokop/video-tools --filter=@vokop/ai-content",
    "dev:gateway": "turbo run dev --filter=@vokop/gateway",
    "dev:video": "turbo run dev --filter=@vokop/video-tools",
    "dev:auth": "turbo run dev --filter=@vokop/auth",
    "dev:studio": "turbo run dev --filter=@vokop/studio",
    "dev:ai": "turbo run dev --filter=@vokop/ai-content",
    "stop": "node scripts/stop-dev.mjs",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@vokop/web",
    "build:admin": "turbo run build --filter=@vokop/admin",
    "build:services": "turbo run build --filter=@vokop/gateway --filter=@vokop/auth --filter=@vokop/studio --filter=@vokop/admin-service --filter=@vokop/video-tools --filter=@vokop/ai-content",
    "lint": "turbo run lint",
    "linecheck": "turbo run linecheck",
    "linecheck:fix": "turbo run linecheck:fix",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "clean": "turbo run clean",
    "test:templates": "pnpm exec tsx scripts/test-studio-templates.ts",
    "test:captions": "pnpm exec tsx scripts/test-caption-segments.ts",
    "test:xfade": "pnpm exec tsx scripts/test-xfade-builder.ts",
    "test:beats": "pnpm --filter @vokop/studio exec tsx ../../scripts/test-beat-detection.ts"
  },
  "devDependencies": {
    "@vokop/devtools": "workspace:*",
    "eslint": "^9.39.1",
    "prettier": "^3.6.2",
    "turbo": "^2.5.4"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.12.1"
}
