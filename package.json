{
  "name": "vokop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm -F @vokop/web -F @vokop/gateway -F @vokop/video-tools --parallel dev",
    "stop": "for p in 3000 3001 4000 4001; do lsof -ti tcp:$p | xargs kill -9 2>/dev/null; done; echo 'Stopped dev servers'",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f",
    "dev:web": "pnpm --filter @vokop/web dev",
    "dev:gateway": "pnpm --filter @vokop/gateway dev",
    "dev:video": "pnpm --filter @vokop/video-tools dev",
    "build": "pnpm run -r build",
    "build:web": "pnpm --filter @vokop/web build",
    "lint": "pnpm run -r lint",
    "clean": "pnpm run -r clean"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.12.1"
}
